# -----------------------------------------------------------------------------
# Verbena development dotenv sample
#
# Copy to .env and adjust values.
#
# Notes:
# - For Docker Compose development, choose one DB overlay (MySQL / PostgreSQL / SQLite).
# - Compose DB overlays set DATABASE_ADAPTER / DATABASE_HOST / DATABASE_PORT for you.
# - Leave VERBENA_DATABASE_USER / VERBENA_DATABASE_PASSWORD unset unless you need to override
#   the adapter-specific defaults from the selected DB overlay.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# DATABASE SETTINGS
# -----------------------------------------------------------------------------

# Common DB base name
DATABASE_NAME=verbena

# Optional overrides when running Rails directly or deviating from the compose defaults
# DATABASE_ADAPTER=mysql2
# DATABASE_HOST=db
# DATABASE_PORT=3306
# DATABASE_FILE=storage/verbena_development.sqlite3

# DB credentials for local development
MYSQL_ROOT_PASSWORD=password
MYSQL_USER=railsuser
MYSQL_PASSWORD=railspass
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# VERBENA_DATABASE_USER=
# VERBENA_DATABASE_PASSWORD=


# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------

# Delivery method: smtp | test | file
VERBENA_DELIVERY_METHOD=test

# SMTP settings (required when VERBENA_DELIVERY_METHOD=smtp)
VERBENA_DELIVERY_SMTP_ADDRESS=localhost
VERBENA_DELIVERY_SMTP_PORT=1025
VERBENA_DELIVERY_SMTP_DOMAIN=localhost
VERBENA_DELIVERY_SMTP_USER_NAME=
VERBENA_DELIVERY_SMTP_PASSWORD=
VERBENA_DELIVERY_SMTP_AUTHENTICATION=plain
VERBENA_DELIVERY_SMTP_ENABLE_STARTTLS_AUTO=true

# Delivery behavior and file mode
VERBENA_ENVELOPE_FROM_OVERRIDE=
VERBENA_FILE_DELIVERY_DIR=tmp/mails
VERBENA_DELIVERY_MAX_RETRIES=5
VERBENA_DELIVERY_LOCK_TTL_SECONDS=300
VERBENA_DELIVERY_LOCK_MAX_SECONDS=3600

# API settings
VERBENA_API_PAGINATION_DEFAULT_LIMIT=50
VERBENA_API_PAGINATION_LIMIT_CAP=1000
VERBENA_API_PAGINATION_DEFAULT_OFFSET=0
VERBENA_API_RESPONSES_DEFAULT_LIMIT=50
VERBENA_API_RESPONSES_LIMIT_CAP=100

# Maintenance and system settings
VERBENA_EML_MAX_BYTES=10485760
VERBENA_CLEANUP_TTL_DAYS=30
VERBENA_LOG_FORMAT=text
VERBENA_ADMIN_USERNAME=
VERBENA_ADMIN_PASSWORD=
