# -----------------------------------------------------------------------------
# Verbena staging dotenv sample
#
# Usage example:
#   cp dot.env.staging.sample .env.staging
#   dotenv -f .env.staging -- kamal deploy -d staging
#
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS (used by Verbena app container)
# -----------------------------------------------------------------------------

# Rails runtime environment for staging deploy
RAILS_ENV=staging

# Rails secret
SECRET_KEY_BASE=

# Database connection (app side)
# Choose one adapter block below.

# [MySQL / MariaDB]
DATABASE_ADAPTER=mysql2
DATABASE_HOST=mysql
DATABASE_PORT=3306

# [PostgreSQL]
# DATABASE_ADAPTER=postgresql
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=

# [SQLite]
# DATABASE_ADAPTER=sqlite3
# DATABASE_FILE=storage/verbena_staging.sqlite3

# Common app DB credentials (used by mysql2/postgresql adapters)
VERBENA_DATABASE_USER=verbena
VERBENA_DATABASE_PASSWORD=

# For database initialization scripts
DATABASE_NAME=verbena
DATABASE_ENVS=staging

# MySQL / MariaDB initdb settings (use when DATABASE_ADAPTER=mysql2)
MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=

# PostgreSQL initdb settings (use when DATABASE_ADAPTER=postgresql)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=

# Delivery settings
VERBENA_DELIVERY_METHOD=smtp
VERBENA_DELIVERY_SMTP_ADDRESS=
VERBENA_DELIVERY_SMTP_PORT=
VERBENA_DELIVERY_SMTP_DOMAIN=
VERBENA_DELIVERY_SMTP_USER_NAME=
VERBENA_DELIVERY_SMTP_PASSWORD=
VERBENA_DELIVERY_SMTP_AUTHENTICATION=login
VERBENA_DELIVERY_SMTP_ENABLE_STARTTLS_AUTO=true
VERBENA_ENVELOPE_FROM_OVERRIDE=
VERBENA_FILE_DELIVERY_DIR=tmp/mails
VERBENA_DELIVERY_MAX_RETRIES=5
VERBENA_DELIVERY_LOCK_TTL_SECONDS=300
VERBENA_DELIVERY_LOCK_MAX_SECONDS=3600

# API settings
VERBENA_API_PAGINATION_DEFAULT_LIMIT=50
VERBENA_API_PAGINATION_LIMIT_CAP=1000
VERBENA_API_PAGINATION_DEFAULT_OFFSET=0
VERBENA_API_RESPONSES_DEFAULT_LIMIT=50
VERBENA_API_RESPONSES_LIMIT_CAP=100

# Maintenance and system settings
VERBENA_EML_MAX_BYTES=10485760
VERBENA_CLEANUP_TTL_DAYS=30
VERBENA_LOG_FORMAT=text
VERBENA_ADMIN_USERNAME=

# Optional admin auth
VERBENA_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# DEPLOY SETTINGS (used by Kamal ERB in config/deploy.staging.yml)
# -----------------------------------------------------------------------------

# Container image to deploy
DEPLOY_IMAGE=verbena-staging

# Single host for each role
DEPLOY_SERVER_WEB_HOST=
DEPLOY_SERVER_WORKER_HOST=

# Optional container hostnames on the kamal network
DEPLOY_WEB_HOSTNAME=verbena-web
DEPLOY_WORKER_HOSTNAME=verbena-worker

# SSH connection settings
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=
DEPLOY_SSH_KEYS=

# DB accessory host (required)
DEPLOY_ACCESSORIES_DB_HOST=
